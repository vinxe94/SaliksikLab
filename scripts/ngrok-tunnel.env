# Copy this file to scripts/ngrok-tunnel.env and adjust values as needed.

# Local web app. SaliksikLab backend commonly runs on 8000.
LOCAL_HOST=localhost
LOCAL_PORT=8000

# Optional: use a reserved/static ngrok domain from your ngrok dashboard.
# Example: NGROK_DOMAIN=your-domain.ngrok-free.app

NGROK_DOMAIN=

# Optional: choose a region when supported by your ngrok account.
NGROK_REGION=

# Optional: protect the public tunnel with basic auth.
# Example: NGROK_BASIC_AUTH=admin:change-this-password

NGROK_BASIC_AUTH=

# stdout works well for terminal and systemd logs.
NGROK_LOG=stdout

