# Copy this file to scripts/reverse-tunnel.env and fill in your VPS details.

# Remote VPS SSH login.
SSH_USER=your_user
SSH_HOST=203.0.113.10
SSH_PORT=22

# Optional SSH key. Leave blank to use your default SSH identity or password auth.
SSH_KEY=

# Local web app.
LOCAL_HOST=localhost
LOCAL_PORT=8000

# Public VPS listener.
# 0.0.0.0 exposes the tunnel on the VPS public IP when GatewayPorts allows it.
REMOTE_BIND=0.0.0.0
REMOTE_PORT=8080

# Set true to use autossh keepalive/reconnect behavior.
USE_AUTOSSH=false
